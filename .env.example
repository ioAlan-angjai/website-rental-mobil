# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# NextAuth.js
NEXTAUTH_SECRET="your-nextauth-secret-here-generate-with-openssl"
NEXTAUTH_URL="http://localhost:3000"

# Supabase (untuk storage & realtime)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Uploadthing (untuk upload bukti bayar)
UPLOADTHING_SECRET="your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"

# Resend (untuk email notifications)
RESEND_API_KEY="your-resend-api-key"

# Midtrans Payment Gateway (optional - untuk auto QRIS generate)
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_IS_PRODUCTION="false"

# Bank Account Info (untuk manual transfer)
BANK_BCA_NUMBER="1234567890"
BANK_BCA_NAME="PT RentalMobil Jogja"
BANK_BNI_NUMBER="0987654321"
BANK_BNI_NAME="PT RentalMobil Jogja"
BANK_MANDIRI_NUMBER="1122334455"
BANK_MANDIRI_NAME="PT RentalMobil Jogja"

# Admin Default
ADMIN_EMAIL="admin@rentalmobil.com"
ADMIN_PASSWORD="change-this-password"
